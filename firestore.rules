rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SECUREENTRY APPLICATION SECURITY RULES
     * 
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model. Every piece of user data 
     * is protected by ensuring that the authenticated user's ID matches the 
     * document's ownership identifier.
     * 
     * Data Structure: 
     * The primary data is stored in the top-level `/user_profiles` collection. 
     * Documents are indexed by the user's Firebase UID ({userId}), creating a 
     * direct 1:1 relationship between authentication and data storage.
     * 
     * Key Security Decisions:
     * 1. Path-Based Authorization: We use the document ID in the path to 
     *    instantly verify ownership without extra database lookups.
     * 2. Denormalization: The 'firebaseUid' is stored inside the document to 
     *    maintain relational integrity and allow for consistent ownership 
     *    validation during updates.
     * 3. No Public Access: All user profile data is strictly private. There 
     *    is no public listing or viewing of profiles.
     * 4. Relational Integrity: On creation, we enforce that the internal 
     *    'firebaseUid' field matches the authenticated user and the path ID.
     */

    // --- Helper Functions ---

    /** 
     * @description Checks if the request is from a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Checks if the user is the owner and the document already exists.
     * Useful for preventing operations on non-existent documents during update/delete.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity, managing individual user account data.
     * @path /user_profiles/{userId}
     * @allow (get) If the authenticated user is the owner of the profile.
     * @allow (create) If the user creates their own profile with a matching firebaseUid.
     * @deny (list) If a user attempts to list all profiles in the system.
     * @principle Restricts access to a user's own data tree and validates relational integrity.
     */
    match /user_profiles/{userId} {
      // READS
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // WRITES
      // Note: On create, we ensure the internal firebaseUid matches the path userId for integrity.
      allow create: if isOwner(userId) && request.resource.data.firebaseUid == userId;
      
      // Note: On update, we ensure the owner cannot transfer the profile to another UID (immutability).
      allow update: if isExistingOwner(userId) && request.resource.data.firebaseUid == resource.data.firebaseUid;
      
      allow delete: if isExistingOwner(userId);
    }

  }
}