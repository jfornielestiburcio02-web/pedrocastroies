
{
  "entities": {
    "Usuario": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Usuario",
      "type": "object",
      "description": "Entidad de usuario con identificador de sesión manual y perfiles educativos.",
      "properties": {
        "usuario": {
          "type": "string",
          "description": "Nombre de usuario único."
        },
        "contrasena": {
          "type": "string",
          "description": "Contraseña en texto plano."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "nombrePersona": {
          "type": "string",
          "description": "Nombre completo de la persona."
        },
        "imagenPerfil": {
          "type": "string",
          "description": "URL de la imagen de perfil."
        },
        "rolesUsuario": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["EsProfesor", "EsAlumno", "EsDireccion", "EsCau", "EsSecretaria"]
          }
        },
        "perfilesAdicionales": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Subperfiles o coordinaciones (ej: Coordinacion IT, Extraescolares, PROA+, PROFESORdad+)."
        },
        "cursoAlumno": {
          "type": "string",
          "description": "Curso asignado al alumno (ej: 4º ESO A)."
        },
        "esTutor": {
          "type": "string",
          "description": "Grupo que tutela el profesor (ej: 2 ESO B)."
        },
        "esDADDe": {
          "type": "string",
          "description": "ID del profesor titular al que este usuario apoya como DAD."
        },
        "sesion": {
          "type": "string",
          "description": "Identificador de sesión (JSESSIONID)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "usuario",
        "contrasena",
        "email"
      ]
    },
    "GrupoAlumnos": {
      "title": "GrupoAlumnos",
      "type": "object",
      "description": "Grupo personalizado de alumnos creado por un profesor.",
      "properties": {
        "profesorId": { "type": "string" },
        "titulo": { "type": "string" },
        "alumnosIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Horario": {
      "title": "Horario",
      "type": "object",
      "description": "Definición de clase o guardia asignada a un profesor.",
      "properties": {
        "profesorId": { "type": "string" },
        "grupoId": { "type": "string", "description": "Referencia al grupo de alumnos vinculado." },
        "dia": { "type": "string", "enum": ["Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo"] },
        "horaInicio": { "type": "string" },
        "horaFin": { "type": "string" },
        "alumnosIds": { "type": "array", "items": { "type": "string" } },
        "esGuardia": { "type": "boolean" },
        "asignatura": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Examen": {
      "title": "Examen",
      "type": "object",
      "description": "Registro de un examen con calificaciones por alumno.",
      "properties": {
        "profesorId": { "type": "string" },
        "claseId": { "type": "string" },
        "titulo": { "type": "string" },
        "fecha": { "type": "string" },
        "mostrarAlumno": { "type": "boolean" },
        "ponderacion": { "type": "number" },
        "notas": { "type": "object", "additionalProperties": { "type": "number" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Tarea": {
      "title": "Tarea",
      "type": "object",
      "description": "Registro de una tarea con seguimiento de entrega por alumno.",
      "properties": {
        "profesorId": { "type": "string" },
        "claseId": { "type": "string" },
        "titulo": { "type": "string" },
        "fecha": { "type": "string" },
        "entregas": { "type": "object", "additionalProperties": { "type": "boolean" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Asistencia": {
      "title": "Asistencia",
      "type": "object",
      "description": "Registro de falta o retraso de un alumno en una clase específica.",
      "properties": {
        "alumnoId": { "type": "string" },
        "claseId": { "type": "string" },
        "fecha": { "type": "string", "description": "Fecha en formato YYYY-MM-DD" },
        "tipo": { "type": "string", "enum": ["I", "R", "J", "H"] },
        "motivo": { "type": "string", "description": "Motivo de la justificación de la falta." },
        "profesorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Comportamiento": {
      "title": "Comportamiento",
      "type": "object",
      "description": "Registro de conducta (positivo/negativo) de un alumno por sesión.",
      "properties": {
        "alumnoId": { "type": "string" },
        "claseId": { "type": "string" },
        "fecha": { "type": "string" },
        "tipo": { "type": "string", "enum": ["Positivo", "Negativo"] },
        "profesorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Incidencia": {
      "title": "Incidencia",
      "type": "object",
      "description": "Registro disciplinario detallado de un alumno.",
      "properties": {
        "alumnoId": { "type": "string" },
        "profesorId": { "type": "string" },
        "curso": { "type": "string" },
        "fecha": { "type": "string", "format": "date-time" },
        "tipoIncidencia": { "type": "string", "enum": ["Contraria", "Grave"] },
        "gravedad": { "type": "number", "minimum": 1, "maximum": 5 },
        "description": { "type": "string" },
        "conductas": { "type": "array", "items": { "type": "string" } },
        "medidasCorrectoras": { "type": "string" },
        "observaciones": { "type": "string" },
        "comunicadoFamilia": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Mensaje": {
      "title": "Mensaje",
      "type": "object",
      "description": "Mensaje de comunicación interna entre usuarios de Rayuela.",
      "properties": {
        "remitenteId": { "type": "string" },
        "destinatarioId": { "type": "string" },
        "asunto": { "type": "string" },
        "cuerpo": { "type": "string" },
        "leido": { "type": "boolean" },
        "eliminado": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "EvaluacionPeriodo": {
      "title": "EvaluacionPeriodo",
      "type": "object",
      "description": "Configuración de un periodo evaluativo por parte de dirección.",
      "properties": {
        "periodo": { "type": "string", "enum": ["1", "2", "3"] },
        "tipoCalificacion": { "type": "string", "enum": ["Numerica", "Cualitativa"] },
        "abiertaProfesores": { "type": "boolean" },
        "abiertaAlumnos": { "type": "boolean" },
        "cursoEscolar": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CalificacionFinal": {
      "title": "CalificacionFinal",
      "type": "object",
      "description": "Registro de calificación final de un periodo para un alumno en una materia.",
      "properties": {
        "alumnoId": { "type": "string" },
        "profesorId": { "type": "string" },
        "claseId": { "type": "string" },
        "periodoId": { "type": "string" },
        "nota": { "type": "string" },
        "observaciones": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "EnlaceInteres": {
      "title": "EnlaceInteres",
      "type": "object",
      "description": "Enlace externo de interés guardado por un profesor.",
      "properties": {
        "profesorId": { "type": "string" },
        "titulo": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ActividadExtraescolar": {
      "title": "ActividadExtraescolar",
      "type": "object",
      "description": "Registro oficial de una actividad complementaria o extraescolar.",
      "properties": {
        "añoAcademico": { "type": "string" },
        "tipoActividad": { "type": "string" },
        "estado": { "type": "string" },
        "departamento": { "type": "string" },
        "coordinadorId": { "type": "string" },
        "titulo": { "type": "string" },
        "descripcion": { "type": "string" },
        "bilingue": { "type": "boolean" },
        "alumnadoConvocado": { "type": "number" },
        "alumnadoParticipante": { "type": "number" },
        "porcentajeParticipacion": { "type": "number" },
        "numDocentes": { "type": "number" },
        "numGruposParticipantes": { "type": "number" },
        "numCursosParticipantes": { "type": "number" },
        "incluidaPGA": { "type": "boolean" },
        "fechaAprobacion": { "type": "string" },
        "requiereCopago": { "type": "boolean" },
        "costePorDocente": { "type": "number" },
        "costePorAlumno": { "type": "number" },
        "otrosCostes": { "type": "number" },
        "totalPresupuesto": { "type": "number" },
        "objetivoDepartamento": { "type": "string" },
        "objetivoEspecifico": { "type": "string" },
        "fechaDesde": { "type": "string" },
        "fechaHasta": { "type": "string" },
        "horaInicio": { "type": "string" },
        "horaFin": { "type": "string" },
        "pais": { "type": "string" },
        "provincia": { "type": "string" },
        "municipio": { "type": "string" },
        "localidad": { "type": "string" },
        "lugarDesarrollo": { "type": "string" },
        "medioTransporte": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/usuarios/{usuarioId}": {
      "schema": {
        "$ref": "#/backend/entities/Usuario"
      },
      "description": "Colección de usuarios con gestión de sesión manual."
    },
    "/gruposAlumnos/{grupoId}": {
      "schema": {
        "$ref": "#/backend/entities/GrupoAlumnos"
      },
      "description": "Colección de grupos personalizados creados por profesores."
    },
    "/horarios/{horarioId}": {
      "schema": {
        "$ref": "#/backend/entities/Horario"
      },
      "description": "Colección global de horarios lectivos y guardias."
    },
    "/examenes/{examenId}": {
      "schema": {
        "$ref": "#/backend/entities/Examen"
      },
      "description": "Colección de exámenes realizados."
    },
    "/tareas/{tareaId}": {
      "schema": {
        "$ref": "#/backend/entities/Tarea"
      },
      "description": "Colección de tareas asignadas."
    },
    "/asistenciasInasistencias/{asistenciaId}": {
      "schema": {
        "$ref": "#/backend/entities/Asistencia"
      },
      "description": "Colección de faltas de asistencia y retrasos."
    },
    "/comportamientos/{comportamientoId}": {
      "schema": {
        "$ref": "#/backend/entities/Comportamiento"
      },
      "description": "Colección de registros de comportamiento."
    },
    "/incidencias/{incidenciaId}": {
      "schema": {
        "$ref": "#/backend/entities/Incidencia"
      },
      "description": "Colección de incidencias disciplinarias."
    },
    "/mensajes/{mensajeId}": {
      "schema": {
        "$ref": "#/backend/entities/Mensaje"
      },
      "description": "Colección de mensajes internos entre usuarios."
    },
    "/evaluacionesPeriodos/{periodoId}": {
      "schema": {
        "$ref": "#/backend/entities/EvaluacionPeriodo"
      },
      "description": "Configuración de periodos de evaluación del centro."
    },
    "/calificacionesFinales/{calificacionId}": {
      "schema": {
        "$ref": "#/backend/entities/CalificacionFinal"
      },
      "description": "Colección de calificaciones definitivas por periodo."
    },
    "/enlacesInteres/{enlaceId}": {
      "schema": {
        "$ref": "#/backend/entities/EnlaceInteres"
      },
      "description": "Colección de enlaces de interés personales del profesorado."
    },
    "/actividadesExtraescolares/{actividadId}": {
      "schema": {
        "$ref": "#/backend/entities/ActividadExtraescolar"
      },
      "description": "Colección de actividades complementarias y extraescolares del centro."
    }
  }
}
